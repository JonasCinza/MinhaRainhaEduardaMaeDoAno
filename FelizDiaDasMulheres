<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Eduarda — Feliz Dia das Mulheres</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --rosa-1: #ff5fa2;
      --rosa-2: #ff8fc7;
      --rosa-3: #ffd8ea;
      --lilas: #b56cff;
      --dourado: #ffd36b;
      --texto: #7a2451;
      --texto-suave: #8f4b68;
      --card: rgba(255, 255, 255, 0.78);
      --borda: rgba(255,255,255,0.75);
      --sombra: 0 18px 45px rgba(205, 77, 125, 0.16);
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at top left, rgba(255,255,255,0.6), transparent 35%),
        radial-gradient(circle at bottom right, rgba(255, 211, 107, 0.18), transparent 30%),
        linear-gradient(180deg, #ffc8df 0%, #ffe7f2 42%, #fffafc 100%);
      color: var(--texto);
      position: relative;
    }

    .bg-flowers,
    .bg-flowers::before,
    .bg-flowers::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: 0.7;
      background-image:
        radial-gradient(circle at 8% 14%, rgba(255, 95, 162, 0.22) 0 18px, transparent 19px),
        radial-gradient(circle at 12% 20%, rgba(255, 211, 107, 0.28) 0 8px, transparent 9px),
        radial-gradient(circle at 82% 11%, rgba(181, 108, 255, 0.18) 0 20px, transparent 21px),
        radial-gradient(circle at 88% 78%, rgba(255, 95, 162, 0.18) 0 18px, transparent 19px),
        radial-gradient(circle at 16% 84%, rgba(255, 143, 199, 0.22) 0 24px, transparent 25px),
        radial-gradient(circle at 78% 86%, rgba(255, 211, 107, 0.20) 0 10px, transparent 11px);
    }

    .petals {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 1;
    }

    .hearts {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 1;
    }

    .heart {
      position: absolute;
      bottom: -10vh;
      opacity: 0.75;
      animation: floatUp linear infinite;
      filter: drop-shadow(0 6px 10px rgba(255, 95, 162, 0.25));
    }

    @keyframes floatUp {
      0% { transform: translateY(0) scale(0.8) translateX(0); opacity: 0; }
      10% { opacity: 0.8; }
      50% { transform: translateY(-45vh) scale(1) translateX(18px); opacity: 0.9; }
      100% { transform: translateY(-115vh) scale(1.15) translateX(-18px); opacity: 0; }
    }

    .petals {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 1;
    }

    .petal {
      position: absolute;
      top: -10vh;
      animation: fall linear infinite;
      opacity: 0.82;
      filter: drop-shadow(0 5px 10px rgba(255, 95, 162, 0.18));
    }

    @keyframes fall {
      0% { transform: translateY(-10vh) rotate(0deg) translateX(0); }
      50% { transform: translateY(50vh) rotate(180deg) translateX(15px); }
      100% { transform: translateY(110vh) rotate(360deg) translateX(-15px); }
    }

    .container {
      position: relative;
      z-index: 2;
      width: min(1180px, 92%);
      margin: 0 auto;
      padding: 34px 0 80px;
    }

    .hero {
      position: relative;
      overflow: hidden;
      text-align: center;
      background: var(--card);
      backdrop-filter: blur(12px);
      border: 2px solid var(--borda);
      border-radius: 34px;
      padding: 36px 22px;
      box-shadow: var(--sombra);
      margin-bottom: 28px;
    }

    .hero::before {
      content: "🌸 🌷 💖 🌺";
      position: absolute;
      top: 16px;
      right: 18px;
      font-size: 1.1rem;
      opacity: 0.55;
      letter-spacing: 6px;
    }

    .badge {
      display: inline-block;
      background: linear-gradient(90deg, var(--rosa-1), var(--dourado), var(--lilas));
      color: white;
      padding: 10px 18px;
      border-radius: 999px;
      font-weight: bold;
      margin-bottom: 18px;
      box-shadow: 0 10px 22px rgba(255, 115, 179, 0.25);
    }

    h1 {
      font-size: clamp(2.2rem, 7.5vw, 4.7rem);
      line-height: 1.03;
      margin-bottom: 12px;
      letter-spacing: -1px;
      background: linear-gradient(90deg, #ff4fa1, #ff9f43, #9d4edd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: pulseTitle 2.8s ease-in-out infinite;
    }

    @keyframes pulseTitle {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.018); }
    }

    .typing {
      font-size: clamp(1rem, 2vw, 1.35rem);
      min-height: 2.2em;
      font-weight: 700;
      color: #9b2c64;
      margin: 0 auto 14px;
      max-width: 840px;
    }

    .subtext {
      max-width: 820px;
      margin: 0 auto 18px;
      font-size: 1.06rem;
      color: var(--texto-suave);
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .btn {
      text-decoration: none;
      padding: 12px 18px;
      border-radius: 999px;
      font-weight: 700;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      box-shadow: 0 10px 24px rgba(190, 79, 124, 0.16);
    }

    .btn:hover { transform: translateY(-3px); }

    .btn-primary {
      color: white;
      background: linear-gradient(90deg, var(--rosa-1), var(--lilas));
    }

    .btn-secondary {
      color: var(--texto);
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(255,255,255,0.8);
    }

    .section-title {
      text-align: center;
      margin: 18px 0 20px;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      color: #b03272;
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 22px;
      margin: 26px 0 34px;
    }

    .frame {
      position: relative;
      padding: 10px;
      border-radius: 28px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(255,240,248,0.96));
      border: 2px solid rgba(255,255,255,0.82);
      box-shadow:
        0 20px 40px rgba(219, 112, 147, 0.18),
        inset 0 0 0 1px rgba(255, 207, 230, 0.8);
      transform: translateY(0) rotate(0deg);
      transition: transform 0.35s ease, box-shadow 0.35s ease;
      overflow: hidden;
    }

    .frame::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 28px;
      padding: 2px;
      background: linear-gradient(135deg, #ffd36b, #ff7ab6, #c77dff);
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
      opacity: 0.9;
    }

    .frame:hover {
      transform: translateY(-8px) rotate(-1deg);
      box-shadow:
        0 28px 48px rgba(219, 112, 147, 0.24),
        inset 0 0 0 1px rgba(255, 207, 230, 0.9);
    }

    .frame:nth-child(2n):hover { transform: translateY(-8px) rotate(1deg); }
    .frame:nth-child(3n):hover { transform: translateY(-8px) rotate(-2deg); }

    .frame-photo {
      width: 100%;
      height: 330px;
      object-fit: cover;
      border-radius: 22px;
      display: block;
      background: linear-gradient(135deg, #ffd8ea, #ffeec7);
      box-shadow: 0 10px 22px rgba(187, 91, 145, 0.18);
    }

    .frame-caption {
      text-align: center;
      padding: 12px 10px 6px;
      font-weight: 700;
      color: #a13d6d;
      font-size: 0.98rem;
    }

    .message {
      background: linear-gradient(135deg, rgba(255,255,255,0.85), rgba(255, 240, 246, 0.92));
      border-radius: 30px;
      padding: 28px;
      box-shadow: 0 14px 35px rgba(190, 79, 124, 0.14);
      line-height: 1.9;
      font-size: 1.06rem;
      color: #7d3558;
      border: 1px solid rgba(255,255,255,0.7);
    }

    .message p + p { margin-top: 12px; }
    .message strong { color: #c22f75; }

    .footer {
      text-align: center;
      margin-top: 28px;
      color: #a05279;
      font-weight: 700;
    }

    .mini-note {
      margin-top: 14px;
      font-size: 0.94rem;
      color: #9d6880;
      text-align: center;
    }

    @media (max-width: 700px) {
      .container { padding-top: 20px; }
      .hero, .message { border-radius: 24px; }
      .frame-photo { height: 300px; }
    }
  </style>
</head>
<body>
  <div class="bg-flowers"></div>
  <div class="petals" id="petals"></div>
  <div class="hearts" id="hearts"></div>

  <main class="container">
    <section class="hero">
      <div class="badge">🌸 Para Eduarda, uma mulher incrível 🌸</div>
      <h1>Feliz Dia das Mulheres</h1>
      <p class="typing" id="typing"></p>
      <p class="subtext">
        Hoje é dia de celebrar sua força, sua beleza, seu coração e a luz especial que você espalha por onde passa. Quero viver muitas coisas com você.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="https://www.youtube.com/watch?v=xMuTn1-dFq0&list=RDxMuTn1-dFq0&start_radio=1" target="_blank" rel="noopener noreferrer">▶ Ouvir sua música</a>
        <a class="btn btn-secondary" href="#galeria">Ver fotos lindas</a>
      </div>

      <p class="mini-note">Música escolhida: Dezembro — Arthur NidiZ</p>
    </section>

    <h2 class="section-title" id="galeria">Momentos da Eduarda ✨</h2>

    <section class="gallery">
      <article class="frame">
        <img class="frame-photo" src="foto1.jpeg" alt="Eduarda sorrindo" />
        <div class="frame-caption">Seu sorriso deixa tudo mais bonito 💖</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto2.jpeg" alt="Eduarda em um momento especial" />
        <div class="frame-caption">Linda em cada detalhe 🌷</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto3.jpeg" alt="Eduarda em um retrato delicado" />
        <div class="frame-caption">Um brilho que encanta ✨</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto4.jpeg" alt="Eduarda em uma foto elegante" />
        <div class="frame-caption">Elegância e beleza em uma só pessoa 🌸</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto5.jpeg" alt="Eduarda em um dia de sol" />
        <div class="frame-caption">Até o dia fica mais bonito com você ☀️</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto6.jpeg" alt="Eduarda com crianças em momento especial" />
        <div class="frame-caption">Carinho que transborda amor 💕</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto7.jpeg" alt="Eduarda em um retrato escuro elegante" />
        <div class="frame-caption">Seu jeito é simplesmente inesquecível 🌺</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto9.jpeg" alt="Eduarda com criança sorrindo" />
        <div class="frame-caption">Momentos doces merecem molduras lindas 💐</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto10.jpeg" alt="Eduarda em pose elegante" />
        <div class="frame-caption">Maravilhosa do seu jeito único 💘</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto11.jpeg" alt="Eduarda sorrindo em selfie" />
        <div class="frame-caption">Seu rosto tem paz, charme e luz 🌹</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto12.jpeg" alt="Eduarda em foto no espelho" />
        <div class="frame-caption">Toda linda, toda especial ✨</div>
      </article>

      <article class="frame">
        <img class="frame-photo" src="foto14.jpeg" alt="Eduarda em retrato delicado" />
        <div class="frame-caption">Você merece um jardim inteiro de flores 🌷</div>
      </article>
    </section>

    <section class="message">
      <p><strong>Eduarda,</strong> hoje eu quero te lembrar o quanto você é especial.</p>
      <p>
        Sua força, sua delicadeza, seu carinho e sua beleza fazem você ser uma mulher admirável. Cada detalhe seu deixa a vida mais bonita e mais leve.
      </p>
      <p>
        Neste <strong>Dia das Mulheres</strong>, eu quero que você sinta todo o amor, toda a admiração e todo o orgulho que existem dentro do meu coração por você.
      </p>
      <p>
        <strong>Quero viver muitas coisas com você</strong>, dividir momentos, construir lembranças lindas e seguir admirando essa mulher maravilhosa que você é.
      </p>
      <p>
        Que nunca faltem flores no seu caminho, sorrisos nos seus dias e motivos para se sentir a mulher maravilhosa que você é. <strong>Você é linda, incrível e muito especial.</strong>
      </p>
    </section>

    <p class="footer">Feito com amor para Eduarda, porque ela é maravilhosa 💐</p>
  </main>

  <script>
    const phrases = [
      'Eduarda, você é linda, forte e inesquecível. 💖',
      'Seu sorriso faz meu mundo florescer. 🌸',
      'Hoje e sempre, eu celebro você. ✨',
      'Você merece amor, cuidado e felicidade. 🌷'
    ];

    const typingEl = document.getElementById('typing');
    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;

    function typeLoop() {
      const current = phrases[phraseIndex];
      typingEl.textContent = current.slice(0, charIndex);

      if (!deleting) {
        charIndex++;
        if (charIndex > current.length) {
          deleting = true;
          setTimeout(typeLoop, 1400);
          return;
        }
      } else {
        charIndex--;
        if (charIndex < 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          charIndex = 0;
        }
      }

      setTimeout(typeLoop, deleting ? 32 : 68);
    }

    typeLoop();

    const petals = document.getElementById('petals');
    const hearts = document.getElementById('hearts');
    const symbols = ['🌸', '🌷', '💮', '🌺', '💖', '✨'];
    const heartSymbols = ['💖', '💕', '💗', '💘'];

    for (let i = 0; i < 30; i++) {
      const petal = document.createElement('span');
      petal.className = 'petal';
      petal.textContent = symbols[Math.floor(Math.random() * symbols.length)];
      petal.style.left = Math.random() * 100 + 'vw';
      petal.style.animationDuration = (8 + Math.random() * 10) + 's';
      petal.style.animationDelay = (Math.random() * 8) + 's';
      petal.style.fontSize = (18 + Math.random() * 16) + 'px';
      petals.appendChild(petal);
    }

    for (let i = 0; i < 20; i++) {
      const heart = document.createElement('span');
      heart.className = 'heart';
      heart.textContent = heartSymbols[Math.floor(Math.random() * heartSymbols.length)];
      heart.style.left = Math.random() * 100 + 'vw';
      heart.style.animationDuration = (7 + Math.random() * 8) + 's';
      heart.style.animationDelay = (Math.random() * 8) + 's';
      heart.style.fontSize = (18 + Math.random() * 18) + 'px';
      hearts.appendChild(heart);
    }
  </script>
</body>
</html>
